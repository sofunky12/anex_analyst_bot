# --- Где хранятся activity.db и Telethon session (фаза 2) ---
# Локально не задавай — по умолчанию рядом с проектом, как раньше. На Fly.io
# указывает на persistent volume (см. README, «Деплой на Fly.io»), задаётся
# через fly.toml, а не через .env.
# DATA_DIR=

# --- Личный аккаунт (Telethon) для догрузки истории через /import_history ---
# Данные с my.telegram.org. Session-файл авторизуется один раз вручную в
# консоли (см. README) — history.py сам логиниться не пытается.
TG_SESSION=history_session
TG_PHONE=+79991234567
TG_API_ID=
TG_API_HASH=

# --- bot.py (Bot API) ---
# Токен от @BotFather. Не забудь /setprivacy -> Disable и передобавить бота
# в чат после этого — см. README.
BOT_TOKEN=
# Твой числовой Telegram user id (НЕ TG_API_ID) — узнать, например, у
# @userinfobot. Даёт доступ к /chats и /import_history в личке с ботом.
OWNER_USER_ID=

# Выбор чата теперь динамический — через /activate в самом чате, не через .env.

# --- Шифрование текста сообщений (обязательно, см. README) ---
# Вариант 1 (проще): статический ключ. Сгенерировать: python generate_key.py
DB_ENCRYPTION_KEY=

# Вариант 2 (безопаснее, но пароль вводится при каждом запуске): раскомментируй
# и задай соль вместо ключа выше — DB_ENCRYPTION_KEY тогда должен быть пустым.
# Для bot.py не подходит (нет stdin для пароля) — только для dashboard.py.
# Сгенерировать соль: python -c "import secrets; print(secrets.token_hex(16))"
# DB_ENCRYPTION_SALT=
